# =============================================================================
# .env.example - Copy this file to .env and fill in your values
# Command: cp .env.example .env
# =============================================================================

# --- Tavily Web Search (https://app.tavily.com - free tier: 1000 searches/month) ---
# Required if WEB_SEARCH_PROVIDER = "tavily" in config.py
TAVILY_API_KEY=your-tavily-api-key-here

# --- Opik Observability (https://www.comet.com/opik - free tier available) ---
# Required if ENABLE_OPIK_TRACING = True in config.py
OPIK_API_KEY=your-opik-api-key-here
OPIK_WORKSPACE=your-workspace-name
OPIK_PROJECT_NAME=L3June26_AP

# --- LangSmith (disabled by default, using Opik instead) ---
LANGCHAIN_TRACING_V2=false

# --- OpenAI (only if using openai: models in config.py) ---
# OPENAI_API_KEY=your-openai-api-key-here

# --- Anthropic (only if using anthropic: models in config.py) ---
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --- Neo4j (for future graph DB features) ---
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=your-password-here
